import yfinance as yf
import pandas as pd
import time

print("Downloading the official master list of all listed stocks from NSE...")
try:
    # This downloads the live master CSV file directly from the National Stock Exchange of India
    nse_master_url = "https://archives.nseindia.com/content/equities/EQUITY_LST.csv"
    nse_df = pd.read_csv(nse_master_url)
    
    # Extract the stock symbols and format them for Yahoo Finance (adding '.NS')
    tickers = [str(symbol).strip() + ".NS" for symbol in nse_df['SYMBOL']]
    print(f"Success! Found {len(tickers)} companies listed on the NSE.\n")
except Exception as e:
    print(f"Failed to fetch live NSE list: {e}")
    print("Falling back to a standard backup list...")
    tickers = ["RELIANCE.NS", "TCS.NS", "INFY.NS"] # Fallback

all_data = []
total_stocks = len(tickers)

print("Starting full financial data extraction. This will take a long time...")
print("To stop early or test, you can cancel the GitHub Action at any time.")
print("-" * 50)

for idx, ticker in enumerate(tickers, 1):
    # Print progress to the GitHub logs so you can watch it working live
    if idx % 10 == 0 or idx == 1:
        print(f"Progress: Processed {idx}/{total_stocks} stocks...")

    try:
        stock = yf.Ticker(ticker)
        info = stock.info
        
        # If the ticker doesn't return basic data, skip it (delisted or suspended stocks)
        if not info or 'longName' not in info:
            continue
            
        company_name = info.get('longName', 'N/A')
        sector = info.get('sector', 'N/A')
        
        # Financial Data Points
        market_cap = info.get('marketCap', 'N/A')
        current_price = info.get('currentPrice', info.get('regularMarketPrice', 'N/A'))
        pe_ratio = info.get('trailingPE', 'N/A')
        pb_ratio = info.get('priceToBook', 'N/A')
        total_revenue = info.get('totalRevenue', 'N/A')
        net_income = info.get('netIncomeToCommon', 'N/A')
        book_value = info.get('bookValue', 'N/A')
        debt_to_equity = info.get('debtToEquity', 'N/A')
        roe = info.get('returnOnEquity', 'N/A')

        all_data.append({
            "Ticker": ticker,
            "Company Name": company_name,
            "Sector": sector,
            "Current Price (₹)": current_price,
            "Market Cap (₹)": market_cap,
            "P/E Ratio": pe_ratio,
            "P/B Ratio": pb_ratio,
            "Total Revenue (₹)": total_revenue,
            "Net Income (Profit) (₹)": net_income,
            "Book Value Per Share": book_value,
            "Debt-to-Equity Ratio": debt_to_equity,
            "Return on Equity (ROE %)": roe * 100 if isinstance(roe, float) else 'N/A'
        })
        
        # Mandatory 1.5-second break so Yahoo Finance doesn't block GitHub's IP address
        time.sleep(1.5)
        
    except Exception as e:
        # If one stock errors out, ignore it and keep moving to the next company
        continue

# Save the massive dataset to Excel
df = pd.DataFrame(all_data)
excel_filename = "all_indian_stocks_financials.xlsx"
df.to_excel(excel_filename, index=False)

print(f"\n Finished! Successfully collected data for {len(all_data)} companies.")
print(f"Saved database to '{excel_filename}'")
